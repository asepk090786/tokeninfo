# Copy this file to lb.env and adjust values.

# Public domain served by LB
LB_DOMAIN=token.belajar2026.net

# Balancing strategy: least_conn | round_robin | ip_hash
LB_STRATEGY=least_conn

# Comma-separated backend list.
# Format: host:port
# Example for 4 VPS app nodes:
BACKEND_NODES=10.10.10.11:80,10.10.10.12:80,10.10.10.13:80,10.10.10.14:80

# Upstream name in nginx config
UPSTREAM_NAME=token_exam_backend

# Optional TLS termination on LB:
# ENABLE_TLS=true
# TLS_CERT_PATH=/etc/letsencrypt/live/token.belajar2026.net/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/token.belajar2026.net/privkey.pem
ENABLE_TLS=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# Generated config output path
OUTPUT_PATH=/etc/nginx/sites-available/token-lb.conf
